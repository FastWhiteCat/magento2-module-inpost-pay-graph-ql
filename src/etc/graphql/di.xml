<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\StoreGraphQl\Model\Resolver\Store\StoreConfigDataProvider">
        <arguments>
            <argument name="extendedConfigData" xsi:type="array">
                <item name="inpost_pay_widget_enabled" xsi:type="string">payment/inpost_pay/widget_enabled</item>
                <item name="inpost_pay_show_on_product_cart" xsi:type="string">payment/inpost_pay/show_on_product_cart</item>
                <item name="inpost_pay_show_on_cart" xsi:type="string">payment/inpost_pay/show_on_cart</item>
                <item name="inpost_pay_show_on_checkout_page" xsi:type="string">payment/inpost_pay/show_on_checkout</item>
                <item name="inpost_pay_show_in_minicart" xsi:type="string">payment/inpost_pay/show_in_minicart</item>
                <item name="inpost_pay_show_on_success_page" xsi:type="string">payment/inpost_pay/show_on_success_page</item>
                <item name="inpost_pay_show_on_register_page" xsi:type="string">payment/inpost_pay/show_on_register_page</item>
                <item name="inpost_pay_show_on_login_page" xsi:type="string">payment/inpost_pay/show_on_login_page</item>
                <item name="inpost_pay_widget_color_variant" xsi:type="string">payment/inpost_pay/widget_color_variant</item>
                <item name="inpost_pay_widget_dark_mode" xsi:type="string">payment/inpost_pay/widget_dark_mode</item>
                <item name="inpost_pay_widget_size" xsi:type="string">payment/inpost_pay/widget_size</item>
                <item name="inpost_pay_merchant_client_id" xsi:type="string">payment/inpost_pay/client_merchant_id</item>
                <item name="inpost_pay_sandbox_merchant_client_id" xsi:type="string">payment/inpost_pay/sandbox_client_merchant_id</item>
                <item name="inpost_pay_is_sandbox" xsi:type="string">payment/inpost_pay/sandbox_enabled</item>
                <item name="inpost_pay_widget_script_url" xsi:type="string">payment/inpost_pay/widget_script_url</item>
                <item name="inpost_pay_sandbox_widget_script_url" xsi:type="string">payment/inpost_pay/sandbox_widget_script_url</item>
                <item name="inpost_pay_test_mode_active" xsi:type="string">payment/inpost_pay/test_mode_active</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Checkout\Api\ShippingInformationManagementInterface">
        <plugin name="InPost_InPostPay::registerSaveAddressActionPlugin"
                type="InPost\InPostPay\Plugin\Quote\RegisterSaveAddressActionPlugin" />
    </type>
</config>
